{
  rules: [
    {
      rule: "convert_require",
      current: "path",
      target: {
        name: "luau"
      }
    },
    {
      rule: "remove_comments",
      except: ["^--!"]
    },
    {
      rule: "inject_global_value",
      identifier: "VERSION",
      value: "0.3.1",
    },
    {
      rule: "inject_global_value",
      identifier: "CHANNEL",
      value: "stable",
    },
    {
      rule: "inject_global_value",
      identifier: "SchedulerVersion",
      value: "0.0.4",
    },
    {
      rule: "inject_global_value",
      identifier: "JobsVersion",
      value: "0.0.1",
    },
    {
      rule: "inject_global_value",
      identifier: "TicketsVersion",
      value: "0.0.4",
    }
  ]
}